    {
      "id": "workflow",
      "name": "AI驱动开发工作流",
      "description": "从模糊想法到可运行代码的完整开发工作流，13个Skill分三层协作",
      "coreMechanisms": [
        {
          "id": "guardrails",
          "name": "边界守卫（GUARDRAILS）",
          "description": "每个Skill只做自己阶段的事，AI越界时自动拦截",
          "file": "./workflow/GUARDRAILS.md"
        },
        {
          "id": "project-context",
          "name": "项目上下文协议（PROJECT-CONTEXT）",
          "description": "每个Skill执行前必须读取specs/目录下所有文档，建立完整项目认知",
          "file": "./workflow/PROJECT-CONTEXT.md"
        }
      ],
      "layers": [
        {
          "id": "project-level",
          "name": "项目级（启动时用一次）",
          "description": "从模糊想法到可开始写代码的项目骨架",
          "flow": "需求澄清 → 产品概述 → 技术栈选型 → 目录结构 → 开发规范 → 路线图规划 → 项目初始化",
          "skills": [
            {
              "id": "project-requirements-clarification",
              "name": "项目需求澄清",
              "role": "好奇的合伙人",
              "trigger": "/project-requirements-clarification",
              "output": "specs/项目描述.md",
              "file": "./workflow/project-requirements-clarification/SKILL.md"
            },
            {
              "id": "project-product-overview",
              "name": "产品概述",
              "role": "首席产品官",
              "trigger": "/project-product-overview",
              "output": "specs/产品概述.md",
              "file": "./workflow/project-product-overview/SKILL.md"
            },
            {
              "id": "project-tech-stack",
              "name": "技术栈选型",
              "role": "CTO",
              "trigger": "/project-tech-stack",
              "output": "specs/技术栈.md",
              "file": "./workflow/project-tech-stack/SKILL.md"
            },
            {
              "id": "project-structure",
              "name": "目录结构",
              "role": "系统架构师",
              "trigger": "/project-structure",
              "output": "specs/项目结构.md",
              "file": "./workflow/project-structure/SKILL.md"
            },
            {
              "id": "project-dev-standards",
              "name": "开发规范",
              "role": "技术委员会",
              "trigger": "/project-dev-standards",
              "output": "specs/开发规范.md",
              "file": "./workflow/project-dev-standards/SKILL.md"
            },
            {
              "id": "project-roadmap-planning",
              "name": "路线图规划",
              "role": "技术产品经理",
              "trigger": "/project-roadmap-planning",
              "output": "specs/开发路线图.md",
              "file": "./workflow/project-roadmap-planning/SKILL.md"
            },
            {
              "id": "project-initialization",
              "name": "项目初始化",
              "role": "DevOps工程师",
              "trigger": "/project-initialization",
              "output": "项目骨架 + docs/开发记录/初始化记录.md",
              "file": "./workflow/project-initialization/SKILL.md"
            }
          ]
        },
        {
          "id": "feature-level",
          "name": "功能级（反复使用）",
          "description": "按路线图一个功能一个功能地做",
          "flow": "功能需求澄清 → 技术方案设计 → 任务规划 → 编码实现",
          "iterationFlow": "功能迭代变更 → 编码实现",
          "skills": [
            {
              "id": "feature-requirements-clarification",
              "name": "功能需求澄清",
              "role": "产品经理",
              "trigger": "/feature-requirements-clarification",
              "output": "specs/features/{功能名}.md",
              "file": "./workflow/feature-requirements-clarification/SKILL.md"
            },
            {
              "id": "feature-tech-design",
              "name": "技术方案设计",
              "role": "系统架构师",
              "trigger": "/feature-tech-design",
              "output": "specs/features/{功能名}_技术方案.md",
              "file": "./workflow/feature-tech-design/SKILL.md"
            },
            {
              "id": "feature-task-planning",
              "name": "任务规划",
              "role": "技术主管",
              "trigger": "/feature-task-planning",
              "output": "specs/features/{功能名}_任务规划.md",
              "file": "./workflow/feature-task-planning/SKILL.md"
            },
            {
              "id": "feature-implementation",
              "name": "编码实现",
              "role": "高级开发工程师",
              "trigger": "/feature-implementation",
              "output": "代码 + docs/开发记录/{功能名}_阶段报告.md",
              "file": "./workflow/feature-implementation/SKILL.md"
            },
            {
              "id": "feature-evolution",
              "name": "功能迭代变更",
              "role": "产品架构师",
              "trigger": "/feature-evolution",
              "output": "增量更新 specs/features/ 文档",
              "changeTypes": ["微调(Tweak)", "扩展(Extension)", "重构(Refactor)"],
              "file": "./workflow/feature-evolution/SKILL.md"
            }
          ]
        },
        {
          "id": "general-level",
          "name": "通用（随时使用）",
          "description": "不管在哪个阶段都能用",
          "skills": [
            {
              "id": "bugfix-workflow",
              "name": "BUG修复",
              "role": "高级调试工程师",
              "trigger": "/bugfix-workflow",
              "output": "修复代码 + 单元测试 + docs/BUG修复文档/{BUG名}.md",
              "hardRule": "没复现出来，不准改代码",
              "file": "./workflow/bugfix-workflow/SKILL.md"
            }
          ]
        }
      ],
      "tips": {
        "file": "./workflow/workflow-tips.md",
        "count": 10,
        "highlights": [
          "功能级规划和编码分开窗口",
          "项目级规划尽量在一个窗口内完成",
          "提示词先润色然后存下来复用",
          "改动≤30%用feature-evolution，≥70%重新走流程",
          "改了代码就要同步文档",
          "AI生成的文档花两分钟过一遍"
        ]
      }
    }
  ],
